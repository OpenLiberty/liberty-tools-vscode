{
	"name": "liberty-dev-vscode-ext",
	"displayName": "Liberty Tools",
	"description": "Liberty Tools for Visual Studio Code",
	"version": "26.0.7-SNAPSHOT",
	"publisher": "Open-Liberty",
	"repository": {
		"type": "git",
		"url": "https://github.com/OpenLiberty/liberty-tools-vscode"
	},
	"preview": false,
	"license": "EPL-2.0",
	"engines": {
		"vscode": ">=1.75.0"
	},
	"categories": [
		"Programming Languages"
	],
	"keywords": [
		"Java",
		"Liberty",
		"MicroProfile",
		"Jakarta EE",
		"Cloud Native"
	],
	"icon": "images/ol_logo.png",
	"galleryBanner": {
		"color": "#24243B",
		"theme": "dark"
	},
	"activationEvents": [
		"workspaceContains:**/pom.xml",
		"workspaceContains:**/build.gradle",
		"onCommand:liberty.starterProject",
		"onCommand:liberty.dev.start",
		"onCommand:liberty.dev.stop",
		"onCommand:liberty.dev.custom",
		"onCommand:liberty.dev.run.tests",
		"onCommand:liberty.dev.open.failsafe.report",
		"onCommand:liberty.dev.open.surefire.report",
		"onCommand:liberty.dev.open.gradle.test.report",
		"onCommand:liberty.dev.add.project",
		"onCommand:liberty.dev.remove.project",
		"onView:liberty-dev"
	],
	"main": "./dist/extension",
	"extensionDependencies": [
		"redhat.vscode-microprofile",
		"redhat.vscode-xml",
		"vscjava.vscode-java-debug"
	],
	"contributes": {
		"javaExtensions": [
			"./jars/org.eclipse.lsp4jakarta.jdt.core-0.2.6.jar"
		],
		"xml.javaExtensions": [
			"./jars/liberty-langserver-lemminx-2.4.1-jar-with-dependencies.jar"
		],
		"views": {
			"explorer": [
				{
					"id": "liberty-dev",
					"category": "Liberty",
					"icon": "images/ol_activity_bar_icon.png",
					"name": "%views.explorer.name%"
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "liberty-dev",
				"contents": "%views.welcome.message%"
			}
		],
		"commands": [
			{
				"command": "liberty.dev.show.commands",
				"category": "Liberty",
				"title": "%commands.title.show.commands%"
			},
			{
				"command": "liberty.explorer.refresh",
				"title": "%commands.title.refresh%",
				"category": "Liberty",
				"icon": "$(refresh)"
			},
			{
				"command": "liberty.dev.start",
				"category": "Liberty",
				"title": "%commands.title.start%"
			},
			{
				"command": "liberty.dev.debug",
				"category": "Liberty",
				"title": "%commands.title.debug%"
			},
			{
				"command": "liberty.dev.add.project",
				"category": "Liberty",
				"title": "%commands.title.add.project%",
				"icon": "$(add)"
			},
			{
				"command": "liberty.dev.remove.project",
				"category": "Liberty",
				"title": "%commands.title.remove.project%",
				"icon": "$(remove)"
			},
			{
				"command": "liberty.dev.stop",
				"category": "Liberty",
				"title": "%commands.title.stop%"
			},
			{
				"command": "liberty.dev.custom",
				"category": "Liberty",
				"title": "%commands.title.start.custom%"
			},
			{
				"command": "liberty.dev.start.container",
				"category": "Liberty",
				"title": "%commands.title.start.in.container%"
			},
			{
				"command": "liberty.dev.run.tests",
				"category": "Liberty",
				"title": "%commands.title.run.tests%"
			},
			{
				"command": "liberty.dev.open.failsafe.report",
				"category": "Liberty",
				"title": "%commands.title.view.integration.test.report%"
			},
			{
				"command": "liberty.dev.open.surefire.report",
				"category": "Liberty",
				"title": "%commands.title.view.unit.test.report%"
			},
			{
				"command": "liberty.dev.open.gradle.test.report",
				"category": "Liberty",
				"title": "%commands.title.view.test.report%"
			},
			{
				"command": "liberty.starterProject",
				"category": "Liberty",
				"title": "%commands.title.starter.project%"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "liberty.dev.add.project",
					"when": "explorerResourceIsRoot",
					"group": "liberty"
				},
				{
					"command": "liberty.dev.remove.project",
					"when": "explorerResourceIsRoot",
					"group": "liberty"
				}
			],
			"view/title": [
				{
					"command": "liberty.explorer.refresh",
					"when": "view == liberty-dev",
					"group": "navigation@1"
				},
				{
					"command": "liberty.dev.add.project",
					"when": "view == liberty-dev",
					"group": "navigation@2"
				},
				{
					"command": "liberty.dev.remove.project",
					"when": "view == liberty-dev",
					"group": "navigation@3"
				}
			],
			"view/item/context": [
				{
					"command": "liberty.dev.start",
					"when": "viewItem == libertyMavenProject || viewItem == libertyGradleProject || viewItem == libertyMavenProjectContainer || viewItem == libertyGradleProjectContainer",
					"group": "libertyCore@1"
				},
				{
					"command": "liberty.dev.debug",
					"when": "viewItem == libertyMavenProject || viewItem == libertyGradleProject || viewItem == libertyMavenProjectContainer || viewItem == libertyGradleProjectContainer",
					"group": "libertyCore@3"
				},
				{
					"command": "liberty.dev.stop",
					"when": "viewItem == libertyMavenProject || viewItem == libertyGradleProject || viewItem == libertyMavenProjectContainer || viewItem == libertyGradleProjectContainer",
					"group": "libertyCore@3"
				},
				{
					"command": "liberty.dev.custom",
					"when": "viewItem == libertyMavenProject || viewItem == libertyGradleProject || viewItem == libertyMavenProjectContainer || viewItem == libertyGradleProjectContainer",
					"group": "libertyCore@2"
				},
				{
					"command": "liberty.dev.start.container",
					"when": "viewItem == libertyMavenProjectContainer || viewItem == libertyGradleProjectContainer",
					"group": "libertyCore@2"
				},
				{
					"command": "liberty.dev.run.tests",
					"when": "viewItem == libertyMavenProject || viewItem == libertyGradleProject || viewItem == libertyMavenProjectContainer || viewItem == libertyGradleProjectContainer",
					"group": "libertyCore@4"
				},
				{
					"command": "liberty.dev.open.failsafe.report",
					"when": "viewItem == libertyMavenProject || viewItem == libertyMavenProjectContainer",
					"group": "libertyCore@5"
				},
				{
					"command": "liberty.dev.open.surefire.report",
					"when": "viewItem == libertyMavenProject || viewItem == libertyMavenProjectContainer",
					"group": "libertyCore@6"
				},
				{
					"command": "liberty.dev.open.gradle.test.report",
					"when": "viewItem == libertyGradleProject || viewItem == libertyGradleProjectContainer",
					"group": "libertyCore@5"
				}
			]
		},
		"configuration": [
			{
				"title": "Liberty",
				"properties": {
					"liberty.terminal.useJavaHome": {
						"type": "boolean",
						"default": false,
						"description": "If this value is true, and if the setting java.home has a value, then the environment variable JAVA_HOME will be set to the value of java.home when a new terminal window is created.",
						"scope": "window"
					}
				}
			}
		],
		"keybindings": [
			{
				"mac": "shift+alt+l",
				"win": "shift+alt+l",
				"linux": "shift+alt+l",
				"key": "shift+alt+l",
				"command": "liberty.dev.show.commands"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "webpack --mode production",
		"compile": "webpack --mode none",
		"watch": "webpack --mode development --watch --info-verbosity verbose",
		"test-compile": "tsc -p ./",
		"build": "gulp downloadLibertyLSJars downloadLSP4JakartaJars",
		"downloadLCLS": "gulp downloadLibertyLSJars",
		"buildLcls": "gulp buildLemminxLiberty buildLibertyServer",
		"buildJakarta": "gulp buildJakartaJdt buildJakartaLs",
		"test": "npm run test-compile && extest setup-and-run -o .vscode/settings.json 'out/test/*.js' --code_settings src/test/resources/settings.json",
		"test-maven": "npm run test-compile && extest setup-and-run -o .vscode/settings.json 'out/test/M*.js' --code_settings src/test/resources/settings.json",
		"test-gradle": "npm run test-compile && extest setup-and-run -o .vscode/settings.json 'out/test/G*.js' --code_settings src/test/resources/settings.json",
		"test-unit": "node node_modules/.bin/mocha --config .mocharc.unit.yml"
	},
	"devDependencies": {
		"@types/chai": "4.3.4",
		"@types/mocha": "10.0.0",
		"@types/node": "20.0.0",
		"@types/selenium-webdriver": "4.1.22",
		"@types/sinon": "^21.0.1",
		"@types/unzip-stream": "^0.3.4",
		"@types/vscode": "1.42.0",
		"@typescript-eslint/eslint-plugin": "8.0.0",
		"@typescript-eslint/parser": "8.0.0",
		"@vscode/test-electron": "2.4.0",
		"chai": "4.3.7",
		"clipboardy": "2.3.0",
		"eslint": "9.0.0",
		"fast-xml-parser": "5.8.0",
		"glob": "13.0.0",
		"gulp": "5.0.1",
		"gulp-download2": "1.1.0",
		"gulp-xml": "1.0.5",
		"minimatch": "9.0.7",
		"mocha": "11.7.6",
		"sinon": "^22.0.0",
		"ts-loader": "9.5.7",
		"ts-node": "^10.9.2",
		"typescript": "6.0.3",
		"vscode-extension-tester": "8.21.0",
		"webpack": "5.107.0",
		"webpack-cli": "5.0.0",
		"xml2js": "0.5.0"
	},
	"overrides": {
		"vscode-languageclient": {
			"rimraf": "6.1.3"
		},
		"serialize-javascript": "7.0.5",
		"xml2js": "0.5.0"
	},
	"dependencies": {
		"@types/fs-extra": "8.1.0",
		"@types/semver": "7.3.2",
		"@types/xml2js": "0.4.5",
		"axios": "1.18.0",
		"brace-expansion": "5.0.7",
		"expand-home-dir": "0.0.3",
		"find-java-home": "2.0.0",
		"fs-extra": "9.0.0",
		"gradle-to-js": "2.0.0",
		"jsonpath-plus": "10.3.0",
		"unzip-stream": "0.3.1",
		"vscode-languageclient": "9.0.1"
	}
}
